# Protect /chat and /chat/stream (generate a long random secret)
API_KEY=your_secure_api_key_here

# Cursor API key: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_your_key_here

# Workspace directory for local agents (use /app inside Docker)
CURSOR_WORKSPACE=/app

# Default model for chat
CURSOR_MODEL=composer-2.5

# development | production (production disables /docs)
ENVIRONMENT=development

# Server (host port mapping for docker compose)
HOST=0.0.0.0
PORT=8000
